# Copy to .env.local for local dev, and set the same in Vercel → Settings → Environment Variables

# Workshop API guard — use the SAME secret value for both vars (server checks WORKSHOP_TOKEN; client sends NEXT_PUBLIC_WORKSHOP_TOKEN)
# WORKSHOP_TOKEN=your-shared-secret-here
# NEXT_PUBLIC_WORKSHOP_TOKEN=your-shared-secret-here

# AI providers (server-side — never expose to the client)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# Optional model overrides (verify against vendor docs before the workshop)
# CLAUDE_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-5.5
# OPENAI_SEARCH_MODEL=gpt-5.5
# GEMINI_MODEL=gemini-2.5-flash

# Supabase (server-side — service-role key bypasses RLS, never expose to the client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
