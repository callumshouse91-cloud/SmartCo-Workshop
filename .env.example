# Copy to .env.local for local dev, and set the same in Vercel → Settings → Environment Variables

# Anthropic (server-side)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase (server-side — service-role key bypasses RLS, never expose to the client)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
